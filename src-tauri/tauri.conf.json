{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tracklet",
  "version": "0.1.0",
  "identifier": "com.tracklet.desktop",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "../src/ui-dist"
  },
  "app": {
    "windows": [],
    "macOSPrivateApi": true,
    "withGlobalTauri": true,
    "trayIcon": {
      "id": "main",
      "iconPath": "icons/tray-clock-template.png",
      "iconAsTemplate": false,
      "menuOnLeftClick": false,
      "showMenuOnLeftClick": false,
      "title": ""
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/icon.icns",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon-1024.png"
    ],
    "resources": [
      "icons/tray-clock-template.png"
    ]
  }
}
